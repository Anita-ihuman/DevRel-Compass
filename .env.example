# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — server-side rate limiting for /api/analyze (M1).
# Provision a Redis database (Vercel Marketplace → Upstash, or upstash.com) and
# provide its REST credentials. Two options:
#   1. Set these standard names directly (self-host / upstash.com), or
#   2. Use a Vercel Marketplace Redis/KV integration — it injects prefixed vars
#      like <STORE>_KV_REST_API_URL / _TOKEN, which the app also detects
#      automatically (no need to duplicate them here).
# If no credentials are found, rate limiting is disabled and every analysis is
# allowed (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: max analyses per IP per rolling day. Defaults to 5.
# RATE_LIMIT_PER_DAY=5

# Google Analytics 4 measurement ID (looks like G-XXXXXXXXXX). Set this in your
# Vercel project env. Only loads in production, so local dev won't pollute GA.
NEXT_PUBLIC_GA_ID=

# ── Accounts (M2): Auth.js + Neon Postgres + Resend ─────────────────────────
# Neon Postgres connection string. The Vercel Neon integration injects
# DATABASE_URL automatically; for local dev, paste your Neon connection string.
DATABASE_URL=

# Auth.js session-signing secret. Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Resend API key for sending magic-link emails — get one at resend.com.
AUTH_RESEND_KEY=
# From address. For quick testing, onboarding@resend.dev works with no setup;
# for production, verify your domain in Resend and use e.g. login@yourdomain.com.
AUTH_EMAIL_FROM=onboarding@resend.dev

# Optional social logins (Auth.js reads these automatically; buttons only show
# when set). Set each app's callback URL to:
#   <site>/api/auth/callback/github   and   <site>/api/auth/callback/google
# GitHub: Settings → Developer settings → OAuth Apps → New OAuth App
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Google: Google Cloud Console → APIs & Services → Credentials → OAuth client ID
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated emails allowed to view the private /admin metrics dashboard.
ADMIN_EMAILS=
