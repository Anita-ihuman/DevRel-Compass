# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...          # or sk_test_... for testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — create products in the Stripe dashboard, paste the price_... IDs here
STRIPE_PRICE_STARTER=price_...         # $5 one-time — 10 analyses
STRIPE_PRICE_PRO=price_...             # $15 one-time — 30 analyses
STRIPE_PRICE_UNLIMITED=price_...       # $12/month subscription — unlimited

# Your deployed URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
