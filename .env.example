# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Lemon Squeezy — from app.lemonsqueezy.com (Settings → API)
LEMONSQUEEZY_API_KEY=eyJ0eXAi...           # Settings → API → create a new API key
LEMONSQUEEZY_STORE_ID=12345                # Settings → Stores (the numeric store ID)
LEMONSQUEEZY_VARIANT_MONTHLY=67890         # your $6/month product's variant ID (Products → your product → the variant)
LEMONSQUEEZY_WEBHOOK_SECRET=your-secret    # set when creating the webhook (Settings → Webhooks); points to /api/webhooks/lemonsqueezy

# Your deployed URL (used for the Lemon Squeezy post-payment redirect)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
